# Colony optional LLM voice settings.
#
# The harness runs without these values in deterministic template mode.
# To use an OpenAI-compatible provider for debate speaker messages:
#
#   cp colony/.env.example colony/.env
#   edit colony/.env
#   python3 colony/run_demo.py --voice-mode llm
#
# MiniMax M3 should work here if your MiniMax endpoint exposes an
# OpenAI-compatible /chat/completions API. Put the exact base URL and model
# name from your MiniMax dashboard/docs.

COLONY_LLM_API_KEY=
COLONY_LLM_BASE_URL=
COLONY_LLM_MODEL=minimax-m3
COLONY_LLM_TIMEOUT_SECONDS=30
